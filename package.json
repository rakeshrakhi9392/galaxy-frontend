{
  "name": "galaxy-flow-frontend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/vendor-schemas.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "generate:nodes": "pnpm -C ../backend generate:nodes"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.12",
    "@galaxy/schemas": "file:./packages/galaxy-src",
    "@trigger.dev/react-hooks": "4.5.0",
    "lucide-react": "^1.23.0",
    "next": "15.5.20",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "reactflow": "^11.11.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "eslint": "^9",
    "@playwright/test": "^1.55.0",
    "eslint-config-next": "15.5.20",
    "jsdom": "^29.1.1",
    "msw": "^2.11.2",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
