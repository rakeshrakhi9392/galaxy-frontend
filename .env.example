# Backend API base URL (browser proxy + server-side fetch target)
NEXT_PUBLIC_BACKEND_URL=http://localhost:4010
# Optional server-only override (readable at runtime on Vercel without rebuild)
# BACKEND_URL=https://your-backend.vercel.app

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/workflows
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/workflows

# Used by backend JWT audience validation
FRONTEND_URL=http://localhost:3000
